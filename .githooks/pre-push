#!/usr/bin/env bash
# ────────────────────────────────────────────────────────────────────
# pre-push hook — Prevents direct pushes to release/* branches
# ────────────────────────────────────────────────────────────────────
# Release branches should only be pushed by release-from-feature.sh
# or CI. Set IKE_RELEASE_PUSH=1 to bypass this check.
# ────────────────────────────────────────────────────────────────────

if [[ "${IKE_RELEASE_PUSH}" == "1" ]]; then
    exit 0
fi

CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"

if [[ "${CURRENT_BRANCH}" == release/* ]]; then
    echo "ERROR: Direct pushes to release branches are not allowed."
    echo "       Use scripts/release-from-feature.sh to create releases."
    echo "       Set IKE_RELEASE_PUSH=1 to override (CI only)."
    exit 1
fi

exit 0
