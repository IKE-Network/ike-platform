<?xml version="1.0" encoding="UTF-8"?>
<!--
  IKE Community — Bill of Materials (auto-generated)
  ═══════════════════════════════════════════════════

  Why this module exists
  ─────────────────────
  Maven 4's consumer POM resolves property references in <dependencies>
  but NOT in <dependencyManagement>. When an external project imports a
  BOM via <scope>import</scope>, it receives the consumer POM — so any
  ${…} expressions in managed dependency versions arrive unresolved and
  the build fails. flatten-maven-plugin, the Maven 3 solution for this
  class of problem, has not been updated for the Maven 4 model changes.

  How it works
  ────────────
  This is a stub POM whose dependencyManagement is generated at build
  time by ike:generate-bom. The goal reads ike-parent's managed
  dependencies, resolves all property references to literals, and writes
  a standalone BOM POM (model version 4.0.0 for maximum consumer
  compatibility) that replaces this stub for install/deploy.

  This module MUST appear after ike-parent and ike-maven-plugin in
  the reactor's <subprojects> list.

  External consumers who do not inherit ike-parent can import this BOM:

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>network.ike.platform</groupId>
                <artifactId>ike-bom</artifactId>
                <version>1</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>
-->
<project xmlns="http://maven.apache.org/POM/4.1.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.1.0
         http://maven.apache.org/xsd/maven-4.1.0.xsd">
    <modelVersion>4.1.0</modelVersion>

    <parent>
        <groupId>network.ike.platform</groupId>
        <artifactId>ike-platform</artifactId>
    </parent>

    <artifactId>ike-bom</artifactId>
    <packaging>pom</packaging>

    <name>IKE Bill of Materials</name>
    <description>
        Auto-generated BOM providing centralized dependency version
        management for IKE Community projects. Import this POM for
        version alignment without inheriting ike-parent build conventions.
        Generated from ike-parent's dependencyManagement by ike:generate-bom.
    </description>
    <url>https://github.com/IKE-Network/ike-platform</url>
    <inceptionYear>2026</inceptionYear>

    <licenses>
        <license>
            <name>Apache License, Version 2.0</name>
            <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
            <distribution>repo</distribution>
        </license>
    </licenses>

    <organization>
        <name>IKE Community</name>
        <url>https://ike.network</url>
    </organization>

    <distributionManagement>
        <repository>
            <id>ike-staging</id>
            <url>${deploy.staging.url}</url>
        </repository>
        <snapshotRepository>
            <id>ike-snapshots</id>
            <url>${deploy.snapshot.url}</url>
        </snapshotRepository>
    </distributionManagement>

    <!-- No dependencyManagement here — generated by ike:generate-bom -->

    <build>
        <plugins>
            <plugin>
                <groupId>network.ike.tooling</groupId>
                <artifactId>ike-maven-plugin</artifactId>
                <version>${ike-tooling.version}</version>
                <executions>
                    <execution>
                        <id>generate-bom</id>
                        <goals><goal>generate-bom</goal></goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
